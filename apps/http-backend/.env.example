# Database connection URL (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/drawer_db?schema=public

# Port for the HTTP backend server
PORT=3010

# Origin URL of the frontend for CORS configuration
FRONTEND_URL=http://localhost:3000

# Google Gemini API Key for AI shape generation
GEMINI_API_KEY=your_gemini_api_key_here

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(uuid())
  firstName     String
  lastName      String
  email         String     @unique
  password      String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  chats         Chat[]
  createdShapes Shapes[]   @relation("createdByUser")
  updatedShapes Shapes[]   @relation("updatedByUser")
  roomUsers     roomUser[]

  roomEvents roomEvents[]
}

model Room {
  id         Int          @id @default(autoincrement())
  slug       Int          @unique
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  chats      Chat[]
  Shapes     Shapes[]
  roomUsers  roomUser[]
  roomEvents roomEvents[]
}

model roomUser {
  id        Int      @id @default(autoincrement())
  roomId    Int
  userId    String
  role      role
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  room      Room     @relation(fields: [roomId], references: [id])

  @@unique([roomId, userId])
}

model Chat {
  id        Int      @id @default(autoincrement())
  message   String
  userId    String
  createdAt DateTime @default(now())
  roomId    Int
  room      Room     @relation(fields: [roomId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Shapes {
  id              Int          @id @default(autoincrement())
  roomId          Int
  createdAt       DateTime     @default(now())
  shape           String
  createdByUserId String
  updatedByUserId String
  room            Room         @relation(fields: [roomId], references: [id])
  createdByUser   User         @relation("createdByUser", fields: [createdByUserId], references: [id])
  updatedByUser   User         @relation("updatedByUser", fields: [updatedByUserId], references: [id])
}

model roomEvents {
  id             Int       @id @default(autoincrement())
  roomId         Int
  sequenceNumber Int
  eventType      EventType
  description    String?
  shapeId        Int
  userId         String
  payload        String
  createdAt      DateTime  @default(now())
  room           Room      @relation(fields: [roomId], references: [id])
  user           User      @relation(fields: [userId], references: [id])

  @@unique([roomId, sequenceNumber])
}

enum role {
  Viewer
  Editor
  Owner
}

enum EventType {
  CREATE_SHAPE
  DELETE_SHAPE
  MOVE_SHAPE
  ROTATE_SHAPE
  SCALE_SHAPE
  CHANGE_FILL
  CHANGE_STROKE
  CHANGE_LAYER
  CHANGE_TEXT
  ADD_IMAGE
}